# ── CI/CD Orchestrator Agent — Environment Variables ─────────────────────────
# Copy this file to .env and fill in your values.
# Never commit .env to version control.

# ── App ──────────────────────────────────────────────────────────────────────
# Random secret for Flask sessions — generate with: python -c "import secrets; print(secrets.token_hex(32))"
CICD_SECRET_KEY=changeme-in-production

# Path to SQLite run-history database (default: ~/.cicd_orchestrator/history.db)
# CICD_DB_PATH=/data/history.db

# ── EPAM AI DIAL ─────────────────────────────────────────────────────────────
# Used by both the AI Agent tab and the AI Code Review feature.
# Get your personal key from: https://dial-keys.lab.epam.com
DIAL_API_KEY=your-dial-api-key-here
DIAL_BASE_URL=https://ai-proxy.lab.epam.com
# Model deployed on your DIAL instance (e.g. gpt-4o, gpt-4-turbo, claude-3-5-sonnet)
DIAL_MODEL=gpt-4o

# ── OpenAI (optional fallback) ────────────────────────────────────────────────
# Only needed when explicitly choosing the OpenAI provider in the AI Agent tab.
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini

# ── Azure DevOps ──────────────────────────────────────────────────────────────
# When set, the agent uses these automatically — no manual credential entry needed.
# PAT needs: Code Read+Write, Build Read+Execute
AZURE_DEVOPS_URL=https://dev.azure.com/myorg
AZURE_DEVOPS_PROJECT=MyProject
AZURE_DEVOPS_PAT=your-pat-here

# ── Azure Resources (pre-fill ACA deploy fields) ──────────────────────────────
# Set these once so the deploy forms auto-populate — no manual typing needed.
AZURE_SUBSCRIPTION_ID=your-subscription-id-here
AZURE_RESOURCE_GROUP=my-resource-group
AZURE_ACR_NAME=mycontainerregistry
AZURE_APP_NAME=my-container-app
AZURE_LOCATION=eastus
AZURE_ACA_ENV_NAME=my-aca-environment

# ── GitHub ────────────────────────────────────────────────────────────────────
# Used by push_to_github / trigger-ADO-from-GitHub-Actions features.
# Token needs: repo (full control of private repos), workflow
GITHUB_TOKEN=ghp_your-token-here
GITHUB_OWNER=my-github-org-or-username
GITHUB_REPO=my-repo-name
